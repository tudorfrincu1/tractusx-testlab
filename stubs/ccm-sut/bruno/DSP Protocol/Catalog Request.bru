meta {
  name: Catalog Request
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/v1/dsp/catalog/request
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {}
}

script:post-response {
  if (res.body && res.body["dcat:dataset"] && res.body["dcat:dataset"].length > 0) {
    bru.setVar("dataset_id", res.body["dcat:dataset"][0]["@id"]);
  }
}
