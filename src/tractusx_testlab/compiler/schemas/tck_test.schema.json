{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eclipse-tractusx.github.io/tractusx-testlab/schemas/tck_test.schema.json",
  "title": "TCK Test File",
  "description": "Validates individual TCK test YAML file structure.",
  "type": "object",
  "required": ["id", "metadata"],
  "oneOf": [
    { "required": ["steps"] },
    { "required": ["execution"] }
  ],
  "properties": {
    "kind": {
      "type": "string",
      "const": "test"
    },
    "testlab": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "namespace": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "version", "description"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": true
    },
    "setup": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/step"
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    },
    "execution": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    },
    "teardown": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/step"
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "step": {
      "type": "object",
      "required": ["id", "uses", "name"],
      "properties": {
        "id": { "type": "string" },
        "uses": { "type": "string" },
        "name": { "type": "string" },
        "with": { "type": "object", "additionalProperties": true },
        "returns": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string" },
              "class": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "validate": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["uses"],
            "properties": {
              "uses": { "type": "string" },
              "with": { "type": "object", "additionalProperties": true }
            },
            "additionalProperties": true
          }
        },
        "on_failure": {
          "type": "string",
          "enum": ["abort", "continue", "skip_remaining"]
        }
      },
      "additionalProperties": true
    }
  }
}
