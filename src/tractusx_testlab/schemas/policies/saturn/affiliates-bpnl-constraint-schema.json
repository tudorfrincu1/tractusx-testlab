{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "title": "AffiliatesBpnlConstraint",
  "type": "object",
  "allOf": [{ "$ref": "#/definitions/AffiliatesBpnlConstraint" }],
  "$id": "https://w3id.org/catenax/2025/9/policy/affiliates-bpnl-constraint-schema.json",
  "definitions": {
    "AffiliatesBpnlConstraint": {
      "type": "object",
      "properties": {
        "leftOperand": { "type": "string", "const": "AffiliatesBpnl" },
        "operator": { "type": "string", "const": "isAnyOf" },
        "rightOperand": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/definitions/BpnlRightOperand" }
        }
      },
      "additionalProperties": false
    },
    "BpnlRightOperand": {
      "type": "string",
      "pattern": "^BPNL[0-9A-Z]{12}$"
    }
  }
}
