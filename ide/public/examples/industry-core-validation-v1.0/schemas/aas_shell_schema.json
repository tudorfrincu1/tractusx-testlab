{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AAS Shell Descriptor",
  "description": "Schema for Asset Administration Shell descriptor validation (simplified).",
  "type": "object",
  "properties": {
    "result": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "idShort", "submodelDescriptors"],
        "properties": {
          "id": { "type": "string" },
          "idShort": { "type": "string" },
          "globalAssetId": { "type": "string" },
          "specificAssetIds": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "value"],
              "properties": {
                "name": { "type": "string" },
                "value": { "type": "string" }
              }
            }
          },
          "submodelDescriptors": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "semanticId", "endpoints"],
              "properties": {
                "id": { "type": "string" },
                "semanticId": {
                  "type": "object",
                  "properties": {
                    "type": { "type": "string" },
                    "keys": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "type": { "type": "string" },
                          "value": { "type": "string" }
                        }
                      }
                    }
                  }
                },
                "endpoints": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["interface", "protocolInformation"],
                    "properties": {
                      "interface": { "type": "string" },
                      "protocolInformation": {
                        "type": "object",
                        "required": ["href"],
                        "properties": {
                          "href": { "type": "string", "format": "uri" },
                          "endpointProtocol": { "type": "string" },
                          "endpointProtocolVersion": { "type": "array", "items": { "type": "string" } }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
