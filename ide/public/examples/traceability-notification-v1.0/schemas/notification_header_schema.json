{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Notification Header",
  "description": "Schema for CX-0125 notification header validation.",
  "type": "object",
  "required": ["header", "content"],
  "properties": {
    "header": {
      "type": "object",
      "required": ["notificationId", "senderBPN", "recipientBPN", "classification", "severity", "status", "type"],
      "properties": {
        "notificationId": { "type": "string", "format": "uuid" },
        "senderBPN": { "type": "string", "pattern": "^BPN[LS][0-9A-Z]{12}$" },
        "recipientBPN": { "type": "string", "pattern": "^BPN[LS][0-9A-Z]{12}$" },
        "classification": { "type": "string", "enum": ["QM-Investigation", "QM-Alert"] },
        "severity": { "type": "string", "enum": ["MINOR", "MAJOR", "CRITICAL", "LIFE-THREATENING"] },
        "status": { "type": "string", "enum": ["CREATED", "SENT", "RECEIVED", "ACKNOWLEDGED", "ACCEPTED", "DECLINED", "CLOSED"] },
        "type": { "type": "string", "enum": ["RECEIVE", "UPDATE"] },
        "relatedNotificationId": { "type": "string" },
        "targetDate": { "type": "string", "format": "date-time" },
        "messageId": { "type": "string", "format": "uuid" }
      }
    },
    "content": {
      "type": "object",
      "properties": {
        "information": { "type": "string" },
        "listOfAffectedItems": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
