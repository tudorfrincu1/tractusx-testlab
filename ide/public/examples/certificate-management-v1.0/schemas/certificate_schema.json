{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BusinessPartnerCertificate",
  "description": "Schema for CX-0135 Business Partner Certificate validation.",
  "type": "object",
  "required": ["certificateId", "businessPartnerNumber", "type", "validFrom"],
  "properties": {
    "certificateId": { "type": "string" },
    "businessPartnerNumber": { "type": "string", "pattern": "^BPN[LS][0-9A-Z]{12}$" },
    "type": { "type": "string" },
    "validFrom": { "type": "string", "format": "date-time" },
    "validUntil": { "type": "string", "format": "date-time" },
    "issuer": { "type": "string" },
    "trustLevel": { "type": "string", "enum": ["NONE", "LOW", "MEDIUM", "HIGH", "TRUSTED"] },
    "documentUrl": { "type": "string", "format": "uri" },
    "enclosedData": {
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "mimeType": { "type": "string" }
      }
    }
  }
}
