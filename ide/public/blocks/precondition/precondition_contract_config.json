{
  "type": "precondition_contract_config",
  "label": "Contract Config",
  "description": "Pre-configure a contract definition linking asset and policies before test execution",
  "params": [
    { "name": "asset_id", "type": "variable", "required": true, "description": "Asset ID variable reference" },
    { "name": "access_policy_id", "type": "variable", "required": true, "description": "Access policy ID variable reference" },
    { "name": "usage_policy_id", "type": "variable", "required": true, "description": "Usage policy ID variable reference" }
  ],
  "outputs": [
    {
      "name": "config_result",
      "description": "The contract configuration object",
      "schema": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "resource_type": { "type": "string", "description": "Type of resource (contract_definition)" },
            "resource_id": { "type": "string", "description": "ID of the configured resource" },
            "status": { "type": "string", "description": "Configuration status (created, exists, failed)" }
          }
        }
      },
      "example": [
        { "resource_type": "contract_definition", "resource_id": "contractdef-uuid-789", "status": "created" }
      ]
    }
  ]
}
