{
  "type": "precondition_asset_config",
  "label": "Asset Config",
  "description": "Pre-configure an asset definition that must exist before test execution",
  "params": [
    { "name": "dct_type", "type": "string", "required": true, "description": "DCT Type URI" },
    { "name": "properties", "type": "json", "required": false, "description": "Asset properties (aas:semantic-id, dct:type, etc.)" }
  ],
  "outputs": [
    {
      "name": "config_result",
      "description": "The asset configuration object",
      "schema": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "resource_type": { "type": "string", "description": "Type of resource (asset)" },
            "resource_id": { "type": "string", "description": "ID of the configured resource" },
            "status": { "type": "string", "description": "Configuration status (created, exists, failed)" }
          }
        }
      },
      "example": [
        { "resource_type": "asset", "resource_id": "asset-uuid-123", "status": "created" }
      ]
    }
  ]
}
