{
  "type": "precondition_policy_config",
  "label": "Policy Config",
  "description": "Pre-configure an ODRL policy that must exist before test execution",
  "custom_registration": true,
  "params": [
    { "name": "policy_type", "type": "dropdown", "required": true, "options": ["access", "usage"], "description": "Policy type" },
    { "name": "permissions", "type": "array", "item_type": "odrl_permission", "required": true, "description": "ODRL permission rules" },
    { "name": "prohibitions", "type": "array", "item_type": "odrl_prohibition", "required": false, "description": "ODRL prohibition rules (Saturn only)" },
    { "name": "obligations", "type": "array", "item_type": "odrl_obligation", "required": false, "description": "ODRL obligation rules (Saturn only)" }
  ],
  "outputs": [
    {
      "name": "config_result",
      "description": "The policy configuration object",
      "schema": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "resource_type": { "type": "string", "description": "Type of resource (policy)" },
            "resource_id": { "type": "string", "description": "ID of the configured resource" },
            "status": { "type": "string", "description": "Configuration status (created, exists, failed)" }
          }
        }
      },
      "example": [
        { "resource_type": "policy", "resource_id": "policy-uuid-456", "status": "created" }
      ]
    }
  ]
}
