{
  "type": "query_catalog",
  "label": "Query Catalog",
  "description": "Send a catalog request to the connector and retrieve available offers.",
  "params": [
    { "name": "service", "type": "service_ref", "required": true, "description": "EDC connector service to query" },
    { "name": "counter_party_address", "type": "string", "required": true, "description": "DSP endpoint of the counter-party connector" },
    { "name": "filter_by", "type": "string", "required": false, "description": "Property to filter by (e.g. dct:type)" },
    { "name": "filter_value", "type": "string", "required": false, "description": "Value to match against the filter property" },
    { "name": "operator", "type": "string", "required": false, "description": "Comparison operator (default: =)" }
  ],
  "outputs": [
    {
      "name": "catalog",
      "class": "catalog",
      "description": "The full catalog response",
      "schema": {
        "type": "object",
        "properties": {
          "@id": { "type": "string", "description": "Catalog ID" },
          "datasets": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "@id": { "type": "string", "description": "Dataset/offer ID" },
                "hasPolicy": { "type": "object", "description": "ODRL policy" },
                "distribution": { "type": "array", "description": "Data distribution formats" }
              }
            }
          }
        }
      },
      "example": {
        "@id": "catalog-123",
        "datasets": [
          { "@id": "offer-abc", "hasPolicy": { "@id": "policy-1" }, "distribution": [] }
        ]
      }
    },
    {
      "name": "datasets",
      "class": "datasets",
      "description": "Array of datasets (offers) in the catalog",
      "schema": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "@id": { "type": "string", "description": "Dataset/offer ID" },
            "hasPolicy": { "type": "object", "description": "ODRL policy" },
            "distribution": { "type": "array", "description": "Data distribution formats" }
          }
        }
      },
      "example": [
        { "@id": "offer-abc", "hasPolicy": { "@id": "policy-1" }, "distribution": [] }
      ]
    }
  ]
}
