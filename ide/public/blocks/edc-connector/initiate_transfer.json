{
  "type": "initiate_transfer",
  "label": "Initiate Transfer",
  "description": "Start a data transfer using a finalized contract agreement.",
  "params": [
    { "name": "service", "type": "service_ref", "required": true, "description": "EDC connector service" },
    { "name": "agreement_id", "type": "string", "required": true, "description": "Contract agreement ID from negotiation" },
    { "name": "asset_id", "type": "string", "required": true, "description": "ID of the asset to transfer" },
    { "name": "transfer_type", "type": "dropdown", "required": false, "description": "Transfer type", "options": ["HttpData-PULL", "HttpData-PUSH", "AmazonS3-PUSH"] }
  ],
  "outputs": [
    { "name": "transfer_id", "description": "ID of the transfer process" },
    { "name": "state", "description": "Transfer state" },
    { "name": "data_address", "description": "Endpoint for pulling data (PULL mode)" }
  ]
}
