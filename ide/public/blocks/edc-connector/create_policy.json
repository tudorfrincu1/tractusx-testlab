{
  "type": "create_policy",
  "label": "Create Policy",
  "description": "Create an access/usage policy definition in the connector.",
  "params": [
    { "name": "service", "type": "service_ref", "required": true, "description": "EDC connector service" },
    { "name": "policy_id", "type": "string", "required": false, "description": "Policy ID (auto-generated if omitted)" },
    { "name": "permissions", "type": "array", "item_type": "odrl_permission", "required": true, "description": "ODRL permission rules" },
    { "name": "prohibitions", "type": "array", "item_type": "odrl_prohibition", "required": false, "description": "ODRL prohibition rules" },
    { "name": "obligations", "type": "array", "item_type": "odrl_obligation", "required": false, "description": "ODRL obligation rules" }
  ],
  "outputs": [
    { "name": "policy_id", "description": "ID of the created policy" }
  ]
}
