{
  "type": "http_call",
  "label": "HTTP Call",
  "description": "Send a plain HTTP request to any URL.",
  "params": [
    { "name": "url", "type": "string", "required": true, "description": "Full URL to call" },
    { "name": "method", "type": "dropdown", "required": true, "description": "HTTP method", "options": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
    { "name": "body", "type": "json", "required": false, "description": "Request body (for POST/PUT/PATCH)" },
    { "name": "headers", "type": "json", "required": false, "description": "Additional request headers" },
    { "name": "query_params", "type": "json", "required": false, "description": "URL query parameters" }
  ],
  "outputs": [
    { "name": "status_code", "description": "HTTP status code of the response" },
    { "name": "response_body", "description": "Response body" },
    { "name": "response_headers", "description": "Response headers" }
  ]
}
