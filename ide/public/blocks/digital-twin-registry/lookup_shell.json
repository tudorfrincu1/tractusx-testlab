{
  "type": "lookup_shell",
  "uses": "digital-twin-registry/lookup_shell",
  "sequence": { "type": "outbound", "has_response": true },
  "label": "Lookup Shell",
  "description": "Look up an AAS shell by specific asset IDs.",
  "params": [
    { "name": "service", "type": "service_ref", "required": true, "description": "DTR service to query" },
    { "name": "asset_ids", "type": "json", "required": true, "description": "Specific asset IDs to search for (key-value pairs)" }
  ],
  "outputs": [
    {
      "name": "shell_ids",
      "class": "shell_ids",
      "description": "Array of matching shell IDs",
      "schema": {
        "type": "array",
        "items": { "type": "string" }
      },
      "example": ["shell-001", "shell-002"]
    },
    {
      "name": "shell_descriptors",
      "class": "shell_descriptor",
      "description": "Full shell descriptors for matches",
      "schema": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string", "description": "Shell descriptor ID" },
            "idShort": { "type": "string", "description": "Short identifier" },
            "specificAssetIds": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "value": { "type": "string" }
                }
              }
            },
            "submodelDescriptors": { "type": "array", "description": "Attached submodel descriptors" }
          }
        }
      },
      "example": [
        {
          "id": "shell-001",
          "idShort": "twin-a",
          "specificAssetIds": [{ "name": "serialNumber", "value": "SN-111" }],
          "submodelDescriptors": []
        }
      ]
    }
  ]
}
