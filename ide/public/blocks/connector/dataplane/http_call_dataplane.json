{
  "type": "http_call_dataplane",
  "uses": ["http/call_dataplane", "connector/dataplane/http_request"],
  "sequence": { "type": "outbound", "has_response": true },
  "label": "HTTP Call via Dataplane",
  "description": "Send an HTTP request through an EDC Dataplane using an EDR token for authorization.",
  "params": [
    { "name": "method", "type": "dropdown", "required": true, "description": "HTTP method", "options": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
    { "name": "dataplane_url", "type": "string", "required": true, "description": "Dataplane public API endpoint URL", "accepts": ["dataplane_url", "url"] },
    { "name": "path", "type": "string", "required": false, "description": "Sub-path appended to dataplane URL" },
    { "name": "edr_token", "type": "string", "required": true, "description": "EDR authorization token (from transfer)", "accepts": ["auth_token"] },
    { "name": "headers", "type": "json", "required": false, "description": "Additional request headers" },
    { "name": "body", "type": "json", "required": false, "description": "Request body (for POST/PUT/PATCH)" }
  ],
  "outputs": [
    {
      "name": "status_code",
      "class": "StatusCode",
      "description": "HTTP status code of the response",
      "schema": { "type": "integer" },
      "example": 200
    },
    {
      "name": "response_body",
      "class": "ResponseBody",
      "description": "Response body",
      "schema": { "type": "object", "description": "Parsed JSON response body" },
      "example": { "result": "ok" }
    },
    {
      "name": "response_headers",
      "class": "ResponseHeaders",
      "description": "Response headers",
      "schema": {
        "type": "object",
        "description": "Response headers as key-value pairs"
      },
      "example": { "content-type": "application/json", "x-request-id": "req-123" }
    }
  ]
}
