{
  "type": "query_catalog",
  "uses": "connector/consumer/query_catalog",
  "sequence": { "type": "outbound", "has_response": true },
  "label": "Query Catalog",
  "description": "Send a catalog request to the connector and retrieve available offers.",
  "params": [
    { "name": "counter_party_id", "type": "string", "required": true, "description": "BPN of the counter-party" },
    { "name": "counter_party_address", "type": "string", "required": true, "description": "DSP endpoint of the counter-party connector" },
    { "name": "filter", "type": "object", "required": false, "description": "Filter object containing filter_expression array of { operand_left, operator, operand_right }" }
  ],
  "outputs": [
    {
      "name": "catalog",
      "class": "Catalog",
      "description": "The full catalog response",
      "schema": {
        "type": "object",
        "properties": {
          "@id": { "type": "string", "description": "Catalog ID" },
          "datasets": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "@id": { "type": "string", "description": "Dataset/offer ID" },
                "hasPolicy": { "type": "object", "description": "ODRL policy" },
                "distribution": { "type": "array", "description": "Data distribution formats" }
              }
            }
          }
        }
      },
      "example": {
        "@id": "catalog-123",
        "datasets": [
          { "@id": "offer-abc", "hasPolicy": { "@id": "policy-1" }, "distribution": [] }
        ]
      }
    },
    {
      "name": "datasets",
      "class": "Datasets",
      "description": "Array of datasets (offers) in the catalog",
      "schema": {
        "type": "object",
        "items": {
          "type": "object",
          "properties": {
            "@id": { "type": "string", "description": "Dataset/offer ID" },
            "hasPolicy": { "type": "object", "description": "ODRL policy" },
            "distribution": { "type": "array", "description": "Data distribution formats" }
          }
        }
      },
      "example": [
        { "@id": "offer-abc", "hasPolicy": { "@id": "policy-1" }, "distribution": [] }
      ]
    }
  ]
}
