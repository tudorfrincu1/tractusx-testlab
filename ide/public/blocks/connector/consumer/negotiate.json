{
  "type": "negotiate",
  "uses": "connector/consumer/negotiate",
  "sequence": { "type": "outbound", "has_response": true },
  "label": "Negotiate Contract",
  "description": "Initiate a contract negotiation for a specific offer.",
  "params": [
    { "name": "counter_party_address", "type": "string", "required": true, "description": "DSP endpoint of the counter-party connector" },
    { "name": "offer_id", "type": "string", "required": true, "description": "ID of the offer/policy to negotiate", "accepts": ["offer_id", "uuid", "string"] },
    { "name": "asset_id", "type": "string", "required": true, "description": "ID of the asset to negotiate for", "accepts": ["asset_id", "uuid"] }
  ],
  "outputs": [
    {
      "name": "negotiation_id",
      "class": "negotiation_id",
      "description": "ID of the initiated negotiation",
      "schema": { "type": "string" },
      "example": "neg-001"
    },
    {
      "name": "agreement_id",
      "class": "agreement_id",
      "description": "Contract agreement ID (after finalization)",
      "schema": { "type": "string" },
      "example": "agr-001"
    },
    {
      "name": "state",
      "class": "state",
      "description": "Negotiation state",
      "schema": { "type": "string" },
      "example": "FINALIZED"
    }
  ]
}
