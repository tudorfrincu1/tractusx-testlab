{
  "type": "initiate_transfer",
  "uses": "connector/consumer/initiate_transfer",
  "sequence": { "type": "outbound", "has_response": true },
  "label": "Initiate Transfer",
  "description": "Start a data transfer using a finalized contract agreement.",
  "params": [
    { "name": "service", "type": "service_ref", "required": true, "description": "EDC connector service" },
    { "name": "agreement_id", "type": "string", "required": true, "description": "Contract agreement ID from negotiation", "accepts": ["agreement_id"] },
    { "name": "asset_id", "type": "string", "required": true, "description": "ID of the asset to transfer", "accepts": ["asset_id", "uuid"] },
    { "name": "transfer_type", "type": "dropdown", "required": false, "description": "Transfer type", "options": ["HttpData-PULL", "HttpData-PUSH", "AmazonS3-PUSH"] }
  ],
  "outputs": [
    {
      "name": "transfer_id",
      "class": "transfer_id",
      "description": "ID of the transfer process",
      "schema": { "type": "string" },
      "example": "transfer-001"
    },
    {
      "name": "state",
      "class": "state",
      "description": "Transfer state",
      "schema": { "type": "string" },
      "example": "STARTED"
    },
    {
      "name": "data_address",
      "class": "response_body",
      "description": "Endpoint for pulling data (PULL mode)",
      "schema": {
        "type": "object",
        "properties": {
          "endpoint": { "type": "string", "description": "Data endpoint URL" },
          "authorization": { "type": "string", "description": "EDR authorization token" },
          "type": { "type": "string", "description": "Transfer type identifier" }
        }
      },
      "example": {
        "endpoint": "https://dataplane.example.com/api/public",
        "authorization": "token-xyz",
        "type": "https://w3id.org/idsa/v4.1/HTTP"
      }
    }
  ]
}
