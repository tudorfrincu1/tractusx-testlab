{
  "type": "create_asset",
  "uses": "connector/provider/create_asset",
  "sequence": { "type": "outbound", "has_response": true },
  "label": "Create Asset",
  "description": "Register a new asset in the connector's asset store.",
  "params": [
    { "name": "connector_service", "type": "class", "class": "ConnectorService", "required": true, "description": "EDC connector service" },
    { "name": "asset_id", "type": "string", "required": false, "description": "Asset ID (auto-generated if omitted)" },
    { "name": "name", "type": "string", "required": true, "description": "Human-readable asset name" },
    { "name": "description", "type": "string", "required": false, "description": "Asset description" },
    { "name": "base_url", "type": "string", "required": true, "description": "Data source base URL" },
    { "name": "content_type", "type": "string", "required": false, "description": "MIME content type of the data" },
    { "name": "properties", "type": "json", "required": false, "description": "Additional asset properties (e.g. dct:type, dct:subject, cx-common:version)" }
  ],
  "outputs": [
    {
      "name": "asset_id",
      "class": "AssetId",
      "description": "ID of the created asset",
      "schema": { "type": "string" },
      "example": "asset-uuid-123"
    }
  ]
}
