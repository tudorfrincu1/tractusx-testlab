{
  "type": "retry",
  "label": "Retry Until Success",
  "description": "Retry a sequence of steps until assertions pass or max attempts reached.",
  "container": true,
  "params": [
    { "name": "max_attempts", "type": "number", "required": false, "description": "Maximum number of retry attempts", "default": 3 },
    { "name": "delay_s", "type": "number", "required": false, "description": "Delay in seconds between retries", "default": 1 },
    { "name": "steps", "type": "steps", "required": true, "description": "Steps to retry" }
  ]
}
