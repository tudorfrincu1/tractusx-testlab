{
  "type": "auto_cleanup",
  "label": "Auto Cleanup",
  "description": "Automatically undo everything the test created (assets, policies, shells, submodels). Tracks what Setup and Steps blocks produced and reverses them.",
  "params": [
    { "name": "description", "type": "string", "required": false, "description": "Optional note describing cleanup scope" }
  ],
  "outputs": [
    {
      "name": "cleanup_report",
      "description": "Summary of what was cleaned up",
      "schema": {
        "type": "object",
        "properties": {
          "deleted_assets": { "type": "number", "description": "Count of assets deleted" },
          "deleted_policies": { "type": "number", "description": "Count of policies deleted" },
          "deleted_shells": { "type": "number", "description": "Count of shell descriptors deleted" },
          "errors": { "type": "array", "description": "Any errors encountered during cleanup" }
        }
      },
      "example": { "deleted_assets": 2, "deleted_policies": 1, "deleted_shells": 1, "errors": [] }
    }
  ]
}
